browser firefox
max-items 7

# Base colors
color background red default
color article red default
color listnormal white default
color listfocus red black standout bold
color listnormal_unread red default
color listfocus_unread red black standout bold
color title red default bold
color info black red
color hint-key black red bold
color hint-keys-delimiter black red
color hint-separator black red
color hint-description black red

# List Style
feedlist-format "%?T?│  ├── %5u %t &%t ?"

highlight feedlist " .*" red default bold
highlight feedlist "·+" color9 default
highlight feedlist "[├──│]" color9
highlight feedlist "(│  ├──.|├─ )" color9

# EMPTY
highlight feedlist ".(0/0).*)" color15 default bold
highlight feedlist ".\\(0/[1-9]+\\).*" white black

# Article highlights
# HEAD
highlight article "(^Feed:.*|^Title:.*|^Date:.*|^Link:.*|^Author:.*|^Links:|^Points:.*|^# Comments:.*)" white default
highlight article "(^Article URL:.*|^Comments URL:.*)" white default
highlight article ":.*\\(link\\)$" green default
highlight article ":.*\\(image\\)$" green default

# LINKS
highlight article "https?://[^ ]+" green default
highlight article "\\[[0-9][0-9]*\\]" green default

# LEGACY
highlight article ":.*\\(embedded flash\\)$" magenta default
highlight article "\\[embedded flash: [0-9][0-9]*\\]" magenta default
highlight article "\\[image\\ [0-9]+\\]" magenta default

# SEPARATORS
highlight all "---.*---" color9
color end-of-text-marker color9 default
